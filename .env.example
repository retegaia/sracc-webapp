# Netlify Function + client — URL del progetto Supabase (pubblica)
SUPABASE_URL=

# Client React — chiave pubblica Supabase (inclusa nel bundle)
SUPABASE_ANON_KEY=

# Solo Netlify Function — chiave con accesso admin, mai nel client
SUPABASE_SERVICE_KEY=

# Solo Netlify Function — mai nel client, sempre lato server
ANTHROPIC_API_KEY=

# Netlify Function + script di seed — URL pubblico del sito deployato (senza
# slash finale), usato come redirect del magic link (S2: niente SMTP custom,
# quindi nessun token in path — v. src/pages/MagicLinkAuth.jsx)
SITE_URL=

# Build React (Vite) — alias di SUPABASE_URL
VITE_SUPABASE_URL=

# Build React (Vite) — alias di SUPABASE_ANON_KEY
VITE_SUPABASE_ANON_KEY=
